# Copy this file to .env and adjust. Never commit .env or real secrets.

# App under test
BASE_URL=https://automationexercise.com

# chromium | firefox | webkit
BROWSER=chromium

# true = browser runs hidden (no window), false = watch it run
# CI always forces true, runners have no display
HEADLESS=false

# Parallel Cucumber workers (scenarios are isolated)
PARALLEL=1

# Save a Playwright trace for failed scenarios
TRACE=false

# silent | error | warn | info | debug (debug adds per-step timing)
LOG_LEVEL=info

# Optional: credentials of an existing account for the login scenarios.
# When left empty, the framework register the user and afterwards delete it.
VALID_USER_EMAIL=
VALID_USER_PASSWORD=
VALID_USER_NAME=
