# Copy this file to .env and adjust values. Never commit .env or real secrets.

# Application under test
BASE_URL=https://automationexercise.com

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Run headless (true/false)
HEADLESS=true

# Number of parallel Cucumber workers (scenarios are isolated)
PARALLEL=1

# Capture a Playwright trace for failed scenarios (true/false)
TRACE=false

# Log verbosity: silent | error | warn | info | debug
# info = scenario lifecycle + key flows; debug adds per-step timing detail
LOG_LEVEL=info

# Optional: credentials of an existing account for the login scenarios.
# When left empty, the framework registers (and afterwards deletes) a
# disposable account on the fly, so tests work out of the box.
VALID_USER_EMAIL=
VALID_USER_PASSWORD=
VALID_USER_NAME=
