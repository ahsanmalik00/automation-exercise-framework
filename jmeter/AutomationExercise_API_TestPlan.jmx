        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="S02 - POST /api/verifyLogin (valid credentials)" enabled="true">
          <stringProp name="TestPlan.comments">Expects JSON body responseCode 200 + &quot;User exists!&quot;</stringProp>
          <stringProp name="HTTPSampler.path">/api/verifyLogin</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
