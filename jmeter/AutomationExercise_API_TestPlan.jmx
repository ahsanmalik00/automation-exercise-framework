        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Generate unique signup_email + log credentials" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def uniqueEmail = &quot;qa_signup_&quot; + System.currentTimeMillis() + &quot;_t&quot; + ctx.getThreadNum() + &quot;_&quot; + new Random().nextInt(9999) + &quot;@testmail.com&quot;
vars.put(&quot;signup_email&quot;, uniqueEmail)
// Decoded, copy-pasteable credentials for manual login verification (see jmeter.log)
log.info(&quot;TG01 CREDENTIALS -&gt; email: &quot; + uniqueEmail + &quot; | password: &quot; + vars.get(&quot;PASSWORD&quot;))</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert - HTTP Status 200" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Signup API did not return HTTP 200</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert - JSON responseCode == 201" enabled="true">
            <stringProp name="JSON_PATH">$.responseCode</stringProp>
            <stringProp name="EXPECTED_VALUE">201</stringProp>
            <boolProp name="JSONVALIDATION">true</boolProp>
            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">false</boolProp>
          </JSONPathAssertion>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert - Body contains &apos;User created!&apos;" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="575444686">User created!</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Signup API body does not confirm user creation</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Assert - Response under 8s" enabled="true">
            <stringProp name="DurationAssertion.duration">8000</stringProp>
          </DurationAssertion>
          <hashTree/>
