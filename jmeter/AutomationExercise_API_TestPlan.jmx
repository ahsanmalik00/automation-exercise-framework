            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">// Unique per thread + iteration; reused by the valid-login sampler below
def uniqueEmail = &quot;qa_login_&quot; + System.currentTimeMillis() + &quot;_t&quot; + ctx.getThreadNum() + &quot;_&quot; + new Random().nextInt(9999) + &quot;@testmail.com&quot;
vars.put(&quot;login_email&quot;, uniqueEmail)
log.info(&quot;TG02 CREDENTIALS -&gt; email: &quot; + uniqueEmail + &quot; | password: &quot; + vars.get(&quot;PASSWORD&quot;))</stringProp>
